{
  "name": "rcm-collections",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf node_modules __lwr_cache__ site",
    "postinstall": "node scripts/copy-embedpdf-assets.mjs",
    "heroku-postbuild": "npm run build:prod-compat",
    "dev": "lwr dev",
    "dev:fresh": "node -e \"try{require('fs').rmSync('__lwr_cache__',{recursive:true,force:true})}catch(e){}\" && lwr dev",
    "dev:port": "lwr dev -p 3001",
    "dev:port:fresh": "node -e \"try{require('fs').rmSync('__lwr_cache__',{recursive:true,force:true})}catch(e){}\" && lwr dev -p 3001",
    "dev:compat": "lwr dev --mode compat",
    "build": "node scripts/copy-embedpdf-assets.mjs && lwr build --clean",
    "build:prod-compat": "node scripts/copy-embedpdf-assets.mjs && lwr build --clean --mode prod-compat",
    "start": "lwr start",
    "stage": "yarn build && yarn start",
    "stage:prod-compat": "yarn build:prod-compat && yarn start"
  },
  "dependencies": {
    "@embedpdf/snippet": "^2.14.1",
    "@salesforce-ux/design-system": "^2.26.2",
    "lightning-base-components": "^1.27.2-alpha",
    "lwc": "8.10.0",
    "lwr": "0.18.1"
  },
  "engines": {
    "node": "20.x"
  },
  "volta": {
    "node": "20.16.0"
  }
}
